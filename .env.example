# Vika_Ok v13.1 — Environment Configuration

# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_IDS=123456789,987654321

# === SSH ===
SSH_KEY_PATH=/root/.ssh/id_ed25519

# === LLM Providers ===
# DO Agent (primary)
DO_AI_API_KEY=your_do_api_key_here
DO_AI_BASE_URL=https://iogg7m5bbddipu56tacil5yn.agents.do-ai.run/api/v1

# Groq (fallback + Whisper STT)
GROQ_API_KEY=your_groq_api_key_here

# Gemini (fallback + multimodal)
GEMINI_API_KEY=your_gemini_api_key_here

# === Models ===
MODEL_DO=openai-gpt-oss-120b
MODEL_FAST=llama-3.3-70b-versatile
MODEL_GEMINI=gemini-1.5-pro

# === Qdrant RAG ===
QDRANT_HOST=vika_qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=vika_knowledge

# === Paths ===
HISTORY_FILE=/app/data/history.json
TASKS_FILE=/app/data/tasks.json
LOG_FILE=/app/bot.log
AUDIO_TEMP_DIR=/tmp/vika_audio

# === Limits ===
MAX_HISTORY=30
MAX_HISTORY_STORAGE=60
WEB_SEARCH_TIMEOUT=15

# === Retry Config ===
MAX_RETRIES=3
RETRY_DELAYS=1,3,5

# === Rate Limiting ===
RATE_LIMIT=5
RATE_LIMIT_PERIOD=1

# === Logging ===
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
